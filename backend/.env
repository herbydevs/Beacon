PROXY_HTTP_PORT=80

BACKEND_PORT=8000

FRONTEND_PORT=5173

KEYCLOAK_PORT=8080

POSTGRES_PORT=5436

DATABASE_URL=postgres://user:pass@postgres:5432/beacon

KEYCLOAK_SERVER_URL=http://sso.beacon.local

KEYCLOAK_REALM=beacon

KEYCLOAK_CLIENT_ID=beacon-backend

KEYCLOAK_CLIENT_SECRET=your_generated_client_secret_here

