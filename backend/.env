RUST_LOG=beacon_backend=debug,axum=info,tower_http=debug

BEACON_SECRET_KEY=change_me_to_a_random_32_char_string

DOCKER_HOST=unix:///var/run/docker.sock

MINECRAFT_NETWORK=beacon_servers

BEACON_DATA_DIR=../data/instances